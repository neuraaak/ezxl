#!/bin/bash
# Pre-commit hook — lint, format, and version badge sync
# Runs automatically before each commit via: git config core.hooksPath .hooks

# Get project root (parent of .hooks directory)
PROJECT_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$PROJECT_ROOT"

echo "Running pre-commit checks..."

# Check if uv is available
if ! command -v uv &>/dev/null; then
    echo "Error: uv not found in PATH. Install uv or add it to PATH."
    exit 1
fi

overall_success=true

# -------------------------------------------------------
# STEP 1 — Lint and format via lint.py (with auto-fix)
# -------------------------------------------------------
if [ -f ".scripts/dev/lint.py" ]; then
    echo "Running code quality checks and fixes..."
    if uv run .scripts/dev/lint.py --fix; then
        echo "Code formatting completed"
    else
        echo "Code formatting failed"
        overall_success=false
    fi
else
    echo "Warning: .scripts/dev/lint.py not found, falling back to direct ruff calls..."

    if uv run ruff format src/ezplog; then
        echo "ruff format completed"
    else
        echo "ruff format failed"
        overall_success=false
    fi

    if uv run ruff check --fix src/ezplog; then
        echo "ruff check completed"
    else
        echo "ruff check failed"
        overall_success=false
    fi
fi

# -------------------------------------------------------
# STEP 2 — Sync version.py from pyproject.toml
# -------------------------------------------------------
if [ -f ".scripts/dev/update_version.py" ]; then
    echo "Syncing version.py..."
    if uv run .scripts/dev/update_version.py; then
        echo "version.py updated"
    else
        echo "Warning: Failed to sync version.py (non-blocking)"
    fi
fi

# -------------------------------------------------------
# STEP 3 — Re-stage modified tracked files
# -------------------------------------------------------
if [ "$overall_success" = true ]; then
    echo "Re-staging modified files..."
    if git add -u; then
        echo "Files staged"
    else
        echo "Failed to stage files"
        overall_success=false
    fi
fi

# -------------------------------------------------------
# RESULT
# -------------------------------------------------------
if [ "$overall_success" = true ]; then
    echo "Pre-commit checks passed."
    exit 0
else
    echo "Pre-commit checks failed. Fix the issues above and retry."
    echo "Run manually: uv run .scripts/dev/lint.py --fix"
    exit 1
fi
